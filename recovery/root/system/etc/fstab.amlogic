# Android fstab for Amlogic devices
#<src>          <mnt_point>   <type>  <mnt_flags>  <fs_mgr_flags>
/dev/block/by-name/boot       /boot       emmc    defaults      defaults
/dev/block/by-name/recovery   /recovery   emmc    defaults      defaults
/dev/block/by-name/system     /system     ext4    ro,barrier=1  wait,avb
/dev/block/by-name/vendor     /vendor     ext4    ro,barrier=1  wait,avb
/dev/block/by-name/product    /product    ext4    ro,barrier=1  wait,avb
/dev/block/by-name/userdata   /data       f2fs    nosuid,nodev,noatime,discard  latemount,wait,check,encryptable=footer
/dev/block/by-name/cache      /cache      ext4    nosuid,nodev,noatime,barrier=1  wait,check
/dev/block/by-name/metadata   /metadata   ext4    nosuid,nodev,noatime  wait,check